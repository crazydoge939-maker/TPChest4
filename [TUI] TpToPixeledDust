local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- Состояние
local autoTpEnabled = false
local isInsidePart = false
local touchedConn = nil
local touchEndedConn = nil
local heartbeatConn = nil
local currentPixeledDust = nil
local dustDestroyedConn = nil

-- Создание GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "TpGui"
screenGui.ResetOnSpawn = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

local frame = Instance.new("Frame")
frame.Name = "MainFrame"
frame.Size = UDim2.new(0.1, 0, 0.09, 0)
frame.Position = UDim2.new(0.05, 0, 0.5, 0)
frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
frame.BorderSizePixel = 0
frame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = frame

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(80, 80, 80)
stroke.Thickness = 1
stroke.Parent = frame

local titleLabel = Instance.new("TextLabel")
titleLabel.Name = "Title"
titleLabel.Size = UDim2.new(1, 0, 0.35, 0)
titleLabel.Position = UDim2.new(0, 0, 0, 0)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "TP to PixeledDust"
titleLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
titleLabel.TextSize = 13
titleLabel.Font = Enum.Font.GothamBold
titleLabel.Parent = frame

local toggleButton = Instance.new("TextButton")
toggleButton.Name = "ToggleButton"
toggleButton.Size = UDim2.new(0.9, 0, 0, 28)
toggleButton.Position = UDim2.new(0.05, 0, 0.4, 0)
toggleButton.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
toggleButton.Text = "OFF"
toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleButton.TextSize = 14
toggleButton.Font = Enum.Font.GothamBold
toggleButton.BorderSizePixel = 0
toggleButton.AutoButtonColor = false
toggleButton.Parent = frame

local btnCorner = Instance.new("UICorner")
btnCorner.CornerRadius = UDim.new(0, 6)
btnCorner.Parent = toggleButton

-- === ПЕРЕТАСКИВАНИЕ GUI ===
local dragToggle = nil
local dragStart = nil
local startPos = nil
local dragInput = nil

titleLabel.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragToggle = true
		dragStart = input.Position
		startPos = frame.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragToggle = false
			end
		end)
	end
end)

titleLabel.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragToggle then
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
end)

-- Функция поиска Part "PixeledDust"
local function findPixeledDust()
	for _, descendant in workspace:GetDescendants() do
		if descendant:IsA("BasePart") and descendant.Name == "PixeledDust" then
			return descendant
		end
	end
	return nil
end

-- Функция телепорта
local function teleportToPixeledDust()
	local target = findPixeledDust()
	if target and humanoidRootPart then
		humanoidRootPart.CFrame = target.CFrame + Vector3.new(0, 3, 0)
	end
end

-- Проверка, что касание от персонажа игрока
local function isPlayerPart(hit)
	local hitChar = hit.Parent
	if hitChar and hitChar == character then
		return true
	end
	return false
end

-- Отключение событий касания и отслеживания удаления
local function disableTouchDetection()
	if touchedConn then
		touchedConn:Disconnect()
		touchedConn = nil
	end
	if touchEndedConn then
		touchEndedConn:Disconnect()
		touchEndedConn = nil
	end
	if dustDestroyedConn then
		dustDestroyedConn:Disconnect()
		dustDestroyedConn = nil
	end
	currentPixeledDust = nil
	isInsidePart = false
end

-- Подключение событий касания
local function setupTouchDetection()
	local pixeledDust = findPixeledDust()
	if not pixeledDust then return end

	currentPixeledDust = pixeledDust

	touchedConn = pixeledDust.Touched:Connect(function(hit)
		if not isPlayerPart(hit) then return end

		if not isInsidePart then
			isInsidePart = true
		end
	end)

	touchEndedConn = pixeledDust.TouchEnded:Connect(function(hit)
		if not isPlayerPart(hit) then return end

		-- Небольшая задержка, чтобы другие части тела тоже успели выйти
		task.wait(0.15)

		-- Проверяем, что ни одна часть персонажа больше не касается Part
		local stillTouching = false
		for _, touchingPart in ipairs(pixeledDust:GetTouchingParts()) do
			if isPlayerPart(touchingPart) then
				stillTouching = true
				break
			end
		end

		if not stillTouching then
			isInsidePart = false
		end
	end)

	-- Отслеживание удаления текущего PixeledDust
	dustDestroyedConn = pixeledDust.AncestryChanged:Connect(function(child, parent)
		if parent == nil then
			-- PixeledDust удалён — сбрасываем состояние и переподключаемся к новому
			disableTouchDetection()
			if autoTpEnabled then
				task.wait(0.1)
				setupTouchDetection()
			end
		end
	end)
end

-- Запуск цикла телепорта: телепортирует, если игрок НЕ в PixeledDust
local function startTeleportLoop()
	heartbeatConn = RunService.Heartbeat:Connect(function()
		if autoTpEnabled and not isInsidePart then
			teleportToPixeledDust()
		end
	end)
end

-- Остановка цикла телепорта
local function stopTeleportLoop()
	if heartbeatConn then
		heartbeatConn:Disconnect()
		heartbeatConn = nil
	end
end



-- Отслеживание появления нового PixeledDust в Workspace
workspace.DescendantAdded:Connect(function(descendant)
	if descendant:IsA("BasePart") and descendant.Name == "PixeledDust" then
		if autoTpEnabled and (currentPixeledDust == nil or currentPixeledDust.Parent == nil) then
			disableTouchDetection()
			setupTouchDetection()
		end
	end
end)

-- Обновление персонажа при респавне
player.CharacterAdded:Connect(function(char)
	character = char
	humanoidRootPart = char:WaitForChild("HumanoidRootPart")

	-- Переподключаем детекцию, если режим включён
	if autoTpEnabled then
		disableTouchDetection()
		setupTouchDetection()
	end
end)

-- Логика переключателя
toggleButton.MouseButton1Click:Connect(function()
	autoTpEnabled = not autoTpEnabled

	if autoTpEnabled then
		toggleButton.Text = "ON"
		toggleButton.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
		isInsidePart = false
		setupTouchDetection()
		startTeleportLoop()
	else
		toggleButton.Text = "OFF"
		toggleButton.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
		stopTeleportLoop()
		disableTouchDetection()
	end
end)

screenGui.Parent = player:WaitForChild("PlayerGui")
